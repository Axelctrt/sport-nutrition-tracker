{
  "name": "sport-nutrition-tracker",
  "private": true,
  "version": "0.17.0",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint .",
    "test": "vitest run",
    "test:stability": "vitest run --sequence.shuffle --sequence.seed=20260626",
    "test:watch": "vitest",
    "preview": "vite preview",
    "check": "npm run lint && npm run test && npm run build && npm run audit:mvp && npm run audit:release && npm run audit:security && npm run audit:production && npm run audit:repository",
    "ci": "npm run lint && npm run test && npm run build && npm run audit:mvp && npm run audit:release && npm run audit:security && npm run audit:production && npm run audit:repository",
    "diagnose:off": "node scripts/diagnose-open-food-facts.mjs",
    "audit:mvp": "node scripts/audit-mvp.mjs",
    "audit:release": "node scripts/audit-release.mjs",
    "audit:rc": "node scripts/audit-rc.mjs",
    "audit:stable": "node scripts/audit-rc.mjs --stable",
    "test:e2e": "playwright test",
    "test:e2e:chromium": "playwright test --project=chromium-desktop",
    "test:e2e:webkit": "playwright test --project=webkit-iphone-15",
    "test:e2e:ui": "playwright test --ui",
    "audit:security": "node scripts/audit-security.mjs",
    "audit:production": "node scripts/audit-rc.mjs --auto",
    "audit:repository": "node scripts/audit-repository.mjs",
    "release:verify": "npm run ci && npm run test:stability"
  },
  "dependencies": {
    "@ericblade/quagga2": "^1.12.1",
    "@hookform/resolvers": "^5.4.0",
    "date-fns": "^4.4.0",
    "dexie": "^4.4.4",
    "dexie-cloud-addon": "4.4.13",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-router-dom": "^7.18.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "tailwindcss": "^4.3.1",
    "typescript": "~6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "workbox-window": "^7.4.0"
  }
}
