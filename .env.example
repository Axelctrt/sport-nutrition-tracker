# Synchronisation Dexie Cloud désactivée par défaut pour un environnement local neuf.
VITE_ENABLE_SYNC_PROTOTYPE=false

# URL publique créée par `npx dexie-cloud create`.
# Ne jamais placer dexie-cloud.key, client_id ou client_secret dans une variable VITE_*.
VITE_DEXIE_CLOUD_DATABASE_URL=

# Pesées réelles. Désactivées par défaut dans un environnement local neuf.
VITE_ENABLE_REAL_WEIGHT_SYNC=false

# Activités sportives réelles. Synchronisation manuelle.
VITE_ENABLE_REAL_ACTIVITY_SYNC=false

# Objectifs sportifs. Synchronisation manuelle.
VITE_ENABLE_REAL_GOAL_SYNC=false

# Musculation : exercices personnalisés, modèles, séances et séries.
VITE_ENABLE_REAL_STRENGTH_SYNC=false

# Journal nutritionnel : repas, entrées, objectifs quotidiens et statuts.
VITE_ENABLE_REAL_NUTRITION_JOURNAL_SYNC=false
# Bibliothèque nutritionnelle : produits utiles, recettes et repas favoris.
VITE_ENABLE_REAL_NUTRITION_LIBRARY_SYNC=false

# Suivi nutritionnel : bilans hebdomadaires et ajustements caloriques acceptés.
VITE_ENABLE_REAL_NUTRITION_TRACKING_SYNC=false

# Outils de laboratoire (pesées fictives, C4 manuel, diagnostic détaillé).
# À conserver à false dans un déploiement utilisateur.
VITE_ENABLE_SYNC_DIAGNOSTICS=false
